# DEPENDÊNCIAS DO NODE.JS
# Ignora as pastas de dependências em todos os módulos do monorepo.
# O package.json e package-lock.json garantem a reprodução exata via 'npm install'.

api/node_modules/
frontend/node_modules/
node_modules/
api/.cache/

# CREDENCIAIS E VARIÁVEIS DE AMBIENTE
# Extremamente crítico: impede o vazamento de senhas do PostgreSQL/Supabase e chaves do GCP.
.env
api/.env
frontend/.env
*.env
!.env.example
!frontend/.env.example
env.yaml
api/env.yaml

# LOGS DO NODE/NPM (inclui arquivos gerados pelo Winston em runtime)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
api/combined.log
api/error.log

# ARQUIVOS DE CACHE DO PYTHON (Previne que binários compilados do Python sujem o repositório.)
__pycache__/
*.py[cod]
*$py.class
*.so

# ARQUIVOS DO SISTEMA OPERACIONAL E EDITOR
.vscode/
.DS_Store
Thumbs.db