# DEPENDÊNCIAS DO NODE.JS (Pasta api)
# Ignora a pasta inteira de dependências, pois o package.json e package-lock.json 
# já garantem que a equipe baixe as mesmas versões rodando 'npm install'.

api/node_modules/
node_modules/

# CREDENCIAIS E VARIÁVEIS DE AMBIENTE (Extremamente crítico: impede o vazamento das senhas do PostgreSQL.)
.env
api/.env
*.env

# LOGS DO NODE/NPM
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ARQUIVOS DE CACHE DO PYTHON (Pasta extension), (Previne que binários compilados do Python sujem o repositório.) 
__pycache__/
*.py[cod]
*$py.class
*.so

# ARQUIVOS DO SISTEMA OPERACIONAL E EDITOR (Ignora configurações específicas da sua máquina (Windows/Mac) e do VS Code.)
.vscode/
.DS_Store
Thumbs.db