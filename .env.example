# Copie para .env na raiz do projeto: cp .env.example .env

# Servidor (API exposta em http://localhost:3000)
PORT=3000

# Google Safe Browsing — obrigatório para análise de URLs
# https://console.cloud.google.com/ → Safe Browsing API → credenciais
GOOGLE_API_KEY=

# PostgreSQL (valores padrão compatíveis com docker-compose.yml)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_NAME=sentinela
DB_PORT=5432
