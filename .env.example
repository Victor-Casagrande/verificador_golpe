# Copie para .env na raiz do projeto: cp .env.example .env

# Servidor (API exposta em http://localhost:3000)
PORT=3000

# Google Safe Browsing — obrigatório para análise de URLs
# https://console.cloud.google.com/ → Safe Browsing API → credenciais
GOOGLE_API_KEY=

# JWT — obrigatório para autenticação (use uma string longa e aleatória em produção)
JWT_SECRET=altere_esta_chave_em_producao
JWT_EXPIRES_IN=7d

# OAuth GitHub — https://github.com/settings/developers
# Crie uma OAuth App e cole as credenciais aqui. NÃO commitar valores reais.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/oauth/github/callback

# OAuth Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/oauth/google/callback

# Opcional: redirecionar após login OAuth (senão retorna JSON com token)
# OAUTH_SUCCESS_REDIRECT=http://localhost:5173/auth/callback

# Axe-core no servidor (Puppeteer + Chromium)
AXE_ENABLED=true
AXE_TIMEOUT_MS=45000
# Caminho do Chrome/Chromium (opcional se o binário for detectado automaticamente).
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Docker/Alpine: /usr/lib/chromium/chromium (binário real; evite sobrescrever no .env)
# Render Docker: mesmo caminho + PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# Render Node nativo: deixe vazio — postinstall baixa Chrome em api/.cache/puppeteer
PUPPETEER_EXECUTABLE_PATH=
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true   # use no Docker; omita no Render nativo
# PUPPETEER_CACHE_DIR=/opt/render/project/src/api/.cache/puppeteer  # Render nativo

# PostgreSQL (valores padrão compatíveis com docker-compose.yml)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_NAME=sentinela
DB_PORT=5432

# PostgreSQL — timeouts do pool (ms). Valores curtos fazem o app falhar rápido
# quando o banco está fora, em vez de pendurar a extensão por dezenas de segundos.
DB_CONNECT_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000

# URL para onde o Node.js vai redirecionar após o login gerar o JWT
OAUTH_SUCCESS_REDIRECT=http://localhost:3000/auth/success

# CORS — origens do frontend permitidas a chamar a API
FRONTEND_URL=http://localhost:5173
# Lista extra (vírgula). Inclua 127.0.0.1 se acessar o Vite por IP.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# true = libera localhost/127.0.0.1 em qualquer porta (recomendado com Docker local)
CORS_ALLOW_LOCALHOST=true