{
  "manifest_version": 3,
  "name": "Sentinela APL - Segurança e Acessibilidade",
  "version": "1.0.0",
  "description": "Ferramenta desenvolvida para detectar golpes digitais e verificar acessibilidade. Projeto de Extensão - IFC.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Abrir Sentinela"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
