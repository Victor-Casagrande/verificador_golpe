{
  "manifest_version": 3,
  "name": "SentryVZN",
  "version": "1.0.0",
  "description": "Análise em tempo real de acessibilidade e segurança.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/axe.min.js", "content/content.js"]
    }
  ]
}