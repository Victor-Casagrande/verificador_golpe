# Copie para .env (ou .env.local) na pasta frontend/
# Todas as variáveis precisam do prefixo VITE_ para serem expostas ao bundle.

# URL da API Sentinela. Padrão do backend rodando localmente / Docker:
# URL base da API Sentinela (sem barra no final)
# Local: http://localhost:3000
# Produção (Render): https://verificador-golpe.onrender.com
VITE_API_BASE_URL=http://localhost:3000

# Nome da chave no localStorage onde o JWT é guardado.
VITE_AUTH_STORAGE_KEY=sentinela.jwt
